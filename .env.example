# Turso Database
# สร้างได้ที่ https://app.turso.tech → Create Database → Copy URL & Token
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# Admin API Key (ตั้งเองได้เลย ควรยาว random string)
# ใช้ใน header: X-Admin-Key: your-secret-key
ADMIN_API_KEY=your-secret-admin-key-here

# ใส่ค่า env จริงที่ Cloudflare Dashboard:
# Pages → nlem-drug-guide → Settings → Environment Variables
#
# seed จากเครื่อง (node scripts/seed-non-nlem-turso.mjs) จะเขียนที่ DB จาก TURSO_URL ในไฟล์นี้เท่านั้น —
# ต้องเป็น database เดียวกับที่ Pages ใช้ ถึงจะเห็นข้อมูลบน drug-guide.pages.dev
#
# นำเข้า NLEM ทั้งชาติจาก media.xlsx:
#   python scripts/import-nlem-from-xlsx.py --dry-run
#   python scripts/import-nlem-from-xlsx.py --sql-out data/nlem-national-import.sql
#   python scripts/import-nlem-from-xlsx.py --execute-turso
# (--execute-turso ลบยา NLEM เดิมใน ก–จ₂ แล้วใส่จาก Excel — non-NLEM ใน NON ไม่ถูกลบ)
